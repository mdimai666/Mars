@using Microsoft.FluentUI.AspNetCore.Components
@using Icons = Microsoft.FluentUI.AspNetCore.Components.Icons
@using Microsoft.FluentUI.AspNetCore.Components.Utilities

@typeparam TOption
@inherits FluentComponentBase

<d-grouped-select-dropdown id="@Id" class="@Class" style="@Style">
    @_customButtonStyle
    <FluentButton @onclick="OpenMenu"
                  Appearance="Appearance.Neutral"
                  Style="@ButtonStyle"
                  Class="@ButtonClass"
                  IconEnd="@(new Icons.Regular.Size16.ChevronDown())"
                  Id="@_buttonId">
        @(Value ?? "-Выберите элемент-")
    </FluentButton>
</d-grouped-select-dropdown>

@* без UseMenuService="false" не срабатывают клики на вложенных меню *@
<FluentMenu Anchor="@_buttonId"
            @bind-Open="isMenuOpen"
            UseMenuService="false"
            Anchored="true">
    @foreach (var group in Items)
    {
        @if (group.Count() > 1)
        {
            <FluentMenuItem Label="@group.Key">
                <MenuItems>
                    @foreach (var item in group)
                    {
                        <FluentMenuItem Label="@OptionText(item)"
                                        OnClick="() => SelectItem(item)">
                        </FluentMenuItem>
                    }
                </MenuItems>
            </FluentMenuItem>
        }
        else
        {
            @foreach (var item in group)
            {
                <FluentMenuItem Label="@OptionText(item)"
                                OnClick="() => SelectItem(item)">
                </FluentMenuItem>
            }
        }
    }
</FluentMenu>

@code {
    string _buttonId = "menuButton-" + Guid.NewGuid().ToString();

    [Parameter, EditorRequired] public IEnumerable<IGrouping<string?, TOption>> Items { get; set; } = default!;

    [Parameter, EditorRequired] public virtual Func<TOption, string?> OptionText { get; set; }
    [Parameter, EditorRequired] public virtual Func<TOption, string?> OptionValue { get; set; }
    [Parameter] public virtual Func<TOption, bool>? OptionDisabled { get; set; }
    [Parameter] public virtual EventCallback<TOption?> SelectedOptionChanged { get; set; }

    [Parameter] public string ButtonClass { get; set; } = string.Empty;
    [Parameter] public string ButtonStyle { get; set; } = string.Empty;

    MarkupString _customButtonStyle => new InlineStyleBuilder()
        .AddStyle($"#{_buttonId}::part(content)", "width", "stretch")
        .AddStyle($"#{_buttonId}::part(content)", "text-align", "start")
        .BuildMarkupString();

    public string _value = "";
    [Parameter, EditorRequired]
    public string Value
    {
        get => _value;
        set
        {
            if (value == _value) return;
            _value = value;
            ValueChanged.InvokeAsync(_value);
        }
    }

    [Parameter]
    public EventCallback<string> ValueChanged { get; set; }

    private bool isMenuOpen = false;

    private void OpenMenu()
    {
        isMenuOpen = true;
    }

    private void SelectItem(TOption item)
    {
        Value = OptionValue(item) ?? string.Empty;
        isMenuOpen = false;
        SelectedOptionChanged.InvokeAsync(item);
    }
}
