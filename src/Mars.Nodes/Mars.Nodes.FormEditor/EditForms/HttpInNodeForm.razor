@using AppFront.Shared
@using AppFront.Shared.Components
@using Mars.Nodes.FormEditor.EditForms.Components
@using Microsoft.FluentUI.AspNetCore.Components
@inherits NodeEditForm
@attribute [NodeEditFormForNode(typeof(HttpInNode))]

<div class="form-group compact" style="--fluent-input-label-basis:150px">
    <div class="vstack gap-2">

        <FormItem2 For="() => Node.Method">
            <FluentSelect Items="Node.MethodVariants" @bind-Value=@Node.Method Class="" />
        </FormItem2>

        <FormItem2 For="() => Node.UrlPattern">
            <div class="vstack gap-2">
                <FluentTextField @bind-Value=@Node.UrlPattern Class="w-100" Placeholder="/path/{id}" />
                <div class="vstack gap-2 align-items-start">
                    <a href="@Q.ServerUrlJoin(Node.UrlPattern)" role="button" class="" target="_blank">
                        @Q.ServerUrlJoin(Node.UrlPattern)
                        <i class="bi bi-box-arrow-up-right" style="font-size:10px;"></i>
                    </a>
                    <a role="button" @onclick="@(() => Node.UrlPattern = $"/{Guid.NewGuid()}")">generate guid</a>
                </div>
            </div>
        </FormItem2>

        <FormItem2 For="() => Node.IsRequireAuthorize" Label="Authorize">
            <FluentCheckbox @bind-Value="@Node.IsRequireAuthorize">
                <AutoInputLabel For="() => Node.IsRequireAuthorize" />
            </FluentCheckbox>
        </FormItem2>

        @if (Node.IsRequireAuthorize)
        {
            <SelectRolesField For="() => Node.AllowedRoles" @bind-Value="Node.AllowedRoles" />
        }

        <FormItem2 For="() => Node.AllowMultipart">
            <FluentCheckbox @bind-Value=@Node.AllowMultipart Class="">
            </FluentCheckbox>
        </FormItem2>

        @if (Node.AllowMultipart)
        {
            <FormItem2 For="() => Node.MaxFileSize">
                <FluentTextField @bind-Value=@Node.MaxFileSize Class="" Placeholder="10mb" />
                <div class="hstack gap-2">
                    <a role="button" @onclick="@(() => Node.MaxFileSize = "1mb")">1mb</a>
                    <a role="button" @onclick="@(() => Node.MaxFileSize = "5mb")">5mb</a>
                    <a role="button" @onclick="@(() => Node.MaxFileSize = "10mb")">10mb</a>
                    <a role="button" @onclick="@(() => Node.MaxFileSize = "100mb")">100mb</a>
                </div>
            </FormItem2>
        }
    </div>
</div>

@code {
    [CascadingParameter] Node Value { get; set; } = default!;
    HttpInNode Node { get => (HttpInNode)Value; set => Value = value; }

}
